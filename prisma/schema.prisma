generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CompanyProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String
  companyName        String
  mainProducts       String
  coreAdvantages     String
  targetCustomerType String
  targetMarkets      String
  unsuitableClients  String   @default("")
  isCompleted        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId])
}

model Opportunity {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String
  companyName    String
  website        String?
  description    String?
  additionalInfo String?
  buyerProfile   String?
  productFit     String?
  valueScore     Int?
  approachAngle  String?
  risks          String?
  insight        String?
  summary        String?
  confidenceScore    Int?
  confidenceReason   String?
  decisionAdvice     String?
  rawAnalysis    Json?
  status         String   @default("analyzed")
  decisionStatus     String?  @default("PENDING") // PENDING | DEVELOP | REJECT | CONTACTED
  decisionReason     String?
  decisionNote       String?
  decidedAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  emailDrafts   EmailDraft[]
  feedbacks     Feedback[]
  analysisFeedbacks AnalysisFeedback[]
  businessThreads BusinessThread[]

  @@index([userId])
  @@index([status])
  @@index([decisionStatus])
}

model EmailDraft {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String
  opportunityId String   @db.Uuid
  subject       String
  body          String
  suggestions   String?
  tone          String   @default("professional")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([opportunityId])
}

model Feedback {
  id            String   @id @default(uuid()) @db.Uuid
  opportunityId String   @db.Uuid
  userId        String
  helpful       Boolean?
  editedEmail   Boolean?
  sent          Boolean?
  comment       String?
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([userId])
}

model AnalysisFeedback {
  id            String   @id @default(uuid()) @db.Uuid
  opportunityId String   @db.Uuid
  userId        String
  helpful       Boolean?
  accuracyRating Int?    // 1-5
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([userId])
}

model BusinessThread {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String
  opportunityId    String?  @db.Uuid
  companyName      String?
  title            String
  status           String   @default("active")
  priority         String   @default("medium")
  nextAction       String?
  context          Json?
  contextUpdatedAt DateTime?
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  communications  Communication[]
  opportunity     Opportunity?    @relation(fields: [opportunityId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
}

model Communication {
  id               String   @id @default(uuid()) @db.Uuid
  threadId         String   @db.Uuid
  source           String
  messageBody      String
  isFromCustomer   Boolean
  timestamp        DateTime
  extractedSignals Json?
  createdAt        DateTime @default(now())

  thread BusinessThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([timestamp])
}

model PromptLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?
  sessionId    String?
  promptType   String
  systemPrompt String
  userMessage  String
  rawResponse  Json?
  result       Json?
  model        String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  @@index([promptType])
  @@index([createdAt])
}
